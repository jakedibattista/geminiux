# Google AI / Vertex AI
GEMINI_API_KEY=your-gemini-api-key

# Google Cloud project config
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Firebase Storage
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Internal API secret shared with the Next.js frontend
# Must match AGENT_API_SECRET in .env.local
# Generate with: openssl rand -hex 32
AGENT_API_SECRET=your-random-secret-here

# Comma-separated list of allowed frontend origins for CORS
# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app,https://your-app.run.app
ALLOWED_ORIGINS=http://localhost:3000
