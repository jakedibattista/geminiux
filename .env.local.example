# Firebase client-side config (safe to expose in browser - these are public identifiers)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin SDK (server-side only - keep secret)
# Paste the entire contents of your service account JSON file as a single-line string
# In GCP production, use Secret Manager instead of this env var
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"..."}

# Internal API secret shared between Next.js and the Python agent backend
# Generate with: openssl rand -hex 32
AGENT_API_SECRET=your-random-secret-here

# URL of the Python agent backend
# Local dev: http://localhost:8080
# Production: https://your-cloud-run-service-url
AGENT_BACKEND_URL=http://localhost:8080
